# Veterinary Backend API URL (required when app runs on physical device)
# Use your COMPUTER's IP (where VeterinaryBackend runs), NOT the phone's IP.
# Same Wi-Fi as phone. Find it: Windows: ipconfig | Mac/Linux: ifconfig
# Example: EXPO_PUBLIC_API_BASE_URL=http://192.168.0.105:5000/api
# Replace with your computer's IP (run ipconfig on Windows, look for IPv4)
# Phone (192.168.0.106) is wrong - use the PC running VeterinaryBackend.
EXPO_PUBLIC_API_BASE_URL=https://web.mypetplus.it/api
EXPO_PUBLIC_STREAM_API_KEY=vagm3eern9xq
