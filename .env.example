# Veterinary Backend API URL (required for physical device; optional for emulator)
# - Android emulator: app defaults to http://10.0.2.2:5000/api
# - iOS simulator: app defaults to http://localhost:5000/api
# - Physical device: set to your computer's IP, e.g.:
#   EXPO_PUBLIC_API_BASE_URL=http://192.168.1.5:5000/api
# Copy this file to .env and edit:
# EXPO_PUBLIC_API_BASE_URL=http://YOUR_COMPUTER_IP:5000/api
